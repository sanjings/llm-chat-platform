# 数据库
DATABASE_URL="mysql://root:Root%25123456@127.0.0.1:3306/llm_chat_platform"
# MySQL 8 caching_sha2_password：无 TLS 的 TCP 需向服务器取 RSA 公钥；代码默认 allowPublicKeyRetrieval=true
# 生产若走 TLS 且需关闭：DATABASE_ALLOW_PUBLIC_KEY_RETRIEVAL=false
# DATABASE_CONNECT_TIMEOUT_MS=15000
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# JWT（生产环境务必更换）
JWT_SECRET="your-super-secret-jwt-key-in-development"
JWT_ACCESS_EXPIRES_IN="30m"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD="123456"

# ---------- 大模型（二选一风格，代码在 chat.services.ts 里用 if 分支）----------
# dashscope = 通义千问 DashScope；openai_compatible = DeepSeek 等 OpenAI 兼容接口
LLM_PROVIDER="dashscope"

# 优先用这个；不配时 DashScope 会回退读 DASHSCOPE_API_KEY
LLM_API_KEY="sk-7938f8e044f44271950bb1846902e235"

# 模型名；不配则用默认（通义 qwen-max / 兼容 deepseek-chat）
# 若请求里带 modelId 且命中 chat.services 内映射，则优先按 modelId 选线路与模型，不受此项单独约束
# LLM_MODEL="qwen-max"

# 仅 openai_compatible 需要，默认 DeepSeek
# LLM_BASE_URL="https://api.deepseek.com/v1"

# 兼容旧变量：仅当 LLM_API_KEY 为空且 LLM_PROVIDER=dashscope 时仍可用
# DASHSCOPE_API_KEY="sk-7938f8e044f44271950bb1846902e235"

# 分页 pageSize 上限；0 或不配表示不按环境变量截断
# PAGINATION_MAX_PAGE_SIZE="0"

# 仅当 LLM_PROVIDER=dashscope 时可用，默认不启用
LLM_MARKDOWN_SYSTEM_PROMPT="请使用 Markdown 格式回答。标题、列表、表格、代码块请按标准 Markdown 输出，表格请使用管道分隔列，代码块请返回完整的语言标识（如：```typescript```）。"

