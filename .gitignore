# 依赖目录
**/node_modules/

# 环境变量文件
**/.env.local
**/.env.*.local
apps/backend/.env

# 构建产物
**/dist/
**/build/
apps/backend/**/generated/
**/portal/stats.*
.turbo/

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE 配置
.idea/
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db

# 测试覆盖
coverage/
*.lcov

# TypeScript 构建信息（如 nest -b）
*.tsbuildinfo

# 临时文件
*.tmp
*.temp
.cache/

# Lint 缓存（勿提交）
.eslintcache
.stylelintcache

# husky internals
.husky/_/

# Prisma CLI 生成缓存（任意应用目录下的 .prisma）
**/.prisma/
