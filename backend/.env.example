# 数据库
DATABASE_URL="mysql://root:password@localhost:3306/llm_chat_platform"

# JWT（生产环境务必更换）
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# ---------- 大模型（二选一风格，代码在 chat.services.ts 里用 if 分支）----------
# dashscope = 通义千问 DashScope；openai_compatible = DeepSeek 等 OpenAI 兼容接口
LLM_PROVIDER="dashscope"

# 优先用这个；不配时 DashScope 会回退读 DASHSCOPE_API_KEY
LLM_API_KEY=""

# 模型名；不配则用默认（通义 qwen-max / 兼容 deepseek-chat）
LLM_MODEL=""

# 仅 openai_compatible 需要，默认 DeepSeek
# LLM_BASE_URL="https://api.deepseek.com/v1"

# 兼容旧变量：仅当 LLM_API_KEY 为空且 LLM_PROVIDER=dashscope 时仍可用
# DASHSCOPE_API_KEY="your-dashscope-api-key"

# 分页 pageSize 上限；0 或不配表示不按环境变量截断
# PAGINATION_MAX_PAGE_SIZE="0"

# 仅当 LLM_PROVIDER=dashscope 时可用，默认不启用
# LLM_MARKDOWN_SYSTEM_PROMPT="请使用 Markdown 格式回答。标题、列表、代码块请按标准 Markdown 输出。"